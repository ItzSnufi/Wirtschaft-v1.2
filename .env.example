# OAuth Configuration
# Erhalte diese Keys von:
# - Google: https://console.cloud.google.com
# - Discord: https://discord.com/developers/applications

GOOGLE_CLIENT_ID=deine_google_client_id_hier
GOOGLE_CLIENT_SECRET=dein_google_secret_hier

DISCORD_CLIENT_ID=deine_discord_client_id_hier
DISCORD_CLIENT_SECRET=dein_discord_secret_hier

# Session Secret (für Production ändern!)
